generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Sender {
  you
  her
}

enum MessageType {
  text
  voice
  image
}

enum EventType {
  anniversary
  visit
  movie
  call
  custom
}

enum UserRole {
  Juliet
  Romeo
}

model Room {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  passcode  String
  createdAt DateTime @default(now()) @map("created_at")

  users     User[]
  messages  Message[]
  events    Event[]
  letters   Letter[]
  photos    Photo[]
  wishes    Wish[]
  quizzes   QuizQuestion[]
  playlists Playlist[]
  surprises Surprise[]
  notifications Notification[]

  @@map("rooms")
}

model User {
  id             Int       @id @default(autoincrement())
  role           UserRole
  roomId         Int       @map("room_id")
  latitude       Float?
  longitude      Float?
  locationShared Boolean   @default(false) @map("location_shared")
  lastSeen       DateTime? @map("last_seen")

  room           Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([role, roomId])
  @@map("users")
}

model Message {
  id        Int         @id @default(autoincrement())
  roomId    Int         @map("room_id")
  sender    Sender
  content   String
  type      MessageType @default(text)
  mediaUrl  String?     @map("media_url")
  reactions Json        @default("[]")
  readAt    DateTime?   @map("read_at")
  createdAt DateTime    @default(now()) @map("created_at")

  room      Room        @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Event {
  id        Int       @id @default(autoincrement())
  roomId    Int       @map("room_id")
  title     String
  date      DateTime  @db.Date
  type      EventType
  note      String?
  createdBy String    @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at")

  room      Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("events")
}

model Letter {
  id        Int      @id @default(autoincrement())
  roomId    Int      @map("room_id")
  sender    String
  topFlap   String?  @map("top_flap")
  greeting  String?
  content   String
  closing   String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("letters")
}

model Photo {
  id         Int       @id @default(autoincrement())
  roomId     Int       @map("room_id")
  url        String
  caption    String?
  uploadedBy String    @map("uploaded_by")
  takenAt    DateTime? @map("taken_at") @db.Date
  createdAt  DateTime  @default(now()) @map("created_at")

  room       Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("photos")
}

model Wish {
  id         Int      @id @default(autoincrement())
  roomId     Int      @map("room_id")
  content    String
  author     String
  isRevealed Boolean  @default(false) @map("is_revealed")
  createdAt  DateTime @default(now()) @map("created_at")

  room       Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("wishes")
}

model QuizQuestion {
  id           Int      @id @default(autoincrement())
  roomId       Int      @map("room_id")
  question     String
  options      Json
  correctIndex Int      @map("correct_index")
  createdBy    String   @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")

  room         Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("quiz_questions")
}

model Playlist {
  id        Int              @id @default(autoincrement())
  roomId    Int              @map("room_id")
  name      String
  createdBy String           @map("created_by")
  createdAt DateTime         @default(now()) @map("created_at")

  room      Room             @relation(fields: [roomId], references: [id], onDelete: Cascade)
  tracks    PlaylistTrack[]

  @@map("playlists")
}

model PlaylistTrack {
  id          Int      @id @default(autoincrement())
  playlistId  Int      @map("playlist_id")
  youtubeId   String   @map("youtube_id")
  title       String
  channel     String
  thumbnail   String
  duration    String   @default("")
  addedBy     String   @map("added_by")
  addedAt     DateTime @default(now()) @map("added_at")

  playlist    Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@map("playlist_tracks")
}

model Surprise {
  id          Int      @id @default(autoincrement())
  roomId      Int      @map("room_id")
  title       String
  content     String   @db.Text
  revealDate  DateTime @map("reveal_date")
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("surprises")
}

model Notification {
  id        Int      @id @default(autoincrement())
  roomId    Int      @map("room_id")
  type      String
  message   String
  metadata  Json?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
